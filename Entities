        "https://raw.githubusercontent.com/Ganyu0611/Fog-Mode-Entities/refs/heads/main/Bite%20(1).txt",
        "https://raw.githubusercontent.com/Ganyu0611/Fog-Mode-Entities/refs/heads/main/The%20Broken%20End",
        "https://github.com/Ganyu0611/Fog-Mode-Entities/raw/refs/heads/main/R2"
    }

    local debugLine = "Fog Check: "
    for i, rate in ipairs(rates) do
