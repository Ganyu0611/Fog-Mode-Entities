    -- Tỉ lệ: Người luộc (34), Hunger (20), Spectrum (20), B1T3 (24), Broken End (32), R2 (21)
    local rates = {25, 23, 24, 24, 25, 26} 
    local urls = {
        "https://raw.githubusercontent.com/Ganyu0611/Fog-Mode-Entities/refs/heads/main/Boiled%20One%20(2).txt",
        "https://raw.githubusercontent.com/Ganyu0611/Fog-Mode-Entities/refs/heads/main/Integrity%20(2).txt",
