local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local Players = game:GetService("Players")
local Lighting = game:GetService("Lighting")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local plr = Players.LocalPlayer
local chr = plr.Character or plr.CharacterAdded:Wait()
local hrp = chr:WaitForChild("HumanoidRootPart")
local hum = chr:WaitForChild("Humanoid")
local camera = workspace.CurrentCamera

local mainGameModule = plr.PlayerGui:WaitForChild("MainUI",10):WaitForChild("Initiator",10):FindFirstChild("Main_Game")
local mainGame = nil
if mainGameModule then
    local success, res = pcall(require, mainGameModule)
    if success then mainGame = res end
end

local function showDoorsCaption(text)
    if mainGame and mainGame.caption then
        mainGame.caption("<font color='#FF0000'>"..text.."</font>", true)
    end
end

local colorCorrection = Instance.new("ColorCorrectionEffect", Lighting)
local blur = Instance.new("BlurEffect", Lighting)

local screenGui = Instance.new("ScreenGui", plr.PlayerGui)
screenGui.IgnoreGuiInset = true
local blackFrame = Instance.new("Frame", screenGui)
blackFrame.Size = UDim2.new(1, 0, 1, 0)
blackFrame.BackgroundColor3 = Color3.new(0, 0, 0)
blackFrame.ZIndex = 10000

local startSound = Instance.new("Sound", hrp)
startSound.SoundId = "rbxassetid://125154139097152"
startSound.Volume = 0.01
startSound:Play()

local bgAmbience = Instance.new("Sound", hrp)
bgAmbience.SoundId = "rbxassetid://128597333594002"
bgAmbience.Volume = 0.3
bgAmbience.Looped = true
bgAmbience:Play()

local countdownSfx = Instance.new("Sound", hrp)
countdownSfx.SoundId = "rbxassetid://138365271911299"
countdownSfx.Volume = 3

task.wait(0.4)
blackFrame:Destroy() 
startSound:Stop()

local spectrum = Instance.new("Part")
spectrum.Name = "Spectrum11"
spectrum.Size = Vector3.new(5, 8, 5)
spectrum.Transparency = 1 
spectrum.CanCollide = false
spectrum.Anchored = true
spectrum.Parent = workspace

local billboard = Instance.new("BillboardGui", spectrum)
billboard.Size = UDim2.new(10, 0, 10, 0)
billboard.AlwaysOnTop = true

local specImg = Instance.new("ImageLabel", billboard)
specImg.Size = UDim2.new(1, 0, 1, 0)
specImg.BackgroundTransparency = 1
specImg.Image = "rbxassetid://113000786377700" 
specImg.Parent = billboard

local isChasing = true
local intensity = 0.15
local currentDistance = 50 
local stopDistance = 5 
local totalTime = 12 

local function ApplyEffects()
    if isChasing then
        local shakeOffset = CFrame.new(
            math.random(-100, 100)/100 * intensity,
            math.random(-100, 100)/100 * intensity,
            0
        ) * CFrame.Angles(
            math.rad(math.random(-100, 100)/100 * intensity * 2.5),
            math.rad(math.random(-100, 100)/100 * intensity * 2.5),
            math.rad(math.random(-100, 100)/100 * intensity * 2.5)
        )
        camera.CFrame = camera.CFrame * shakeOffset
        
        colorCorrection.TintColor = Color3.fromRGB(255, math.random(150, 255), math.random(150, 255))
        colorCorrection.Contrast = math.random(0.3, 1.3)
        blur.Size = math.random(1, 6)

        specImg.Position = UDim2.new(0, math.random(-25, 25), 0, math.random(-25, 25))
        specImg.ImageTransparency = math.random(0, 4) / 10
    end
end

local connection
connection = RunService.RenderStepped:Connect(function()
    if spectrum and spectrum.Parent then
        spectrum.CFrame = hrp.CFrame * CFrame.new(0, 0, -currentDistance)
        ApplyEffects()
    else
        if connection then connection:Disconnect() end
    end
end)

for i = totalTime, 0, -1 do
    if i > 10 then
        showDoorsCaption("YoU sTiLL hAvE sOmE TiMe")
    else
        showDoorsCaption(tostring(i))
        countdownSfx:Play()
        
        if i > 2 then
            local speed = (50 - stopDistance) / 8
            currentDistance = currentDistance - speed
        else
            currentDistance = stopDistance 
        end
    end
    task.wait(1)
end

showDoorsCaption("TiMe OuT")
task.wait(1) 

if not chr:GetAttribute("Hiding") then
    pcall(function()
        ReplicatedStorage.GameStats["Player_" .. plr.Name].Total.DeathCause.Value = "SpEcTrUm 11"
    end)
    hum.Health = 0
end

isChasing = false
bgAmbience:Stop()
TweenService:Create(colorCorrection, TweenInfo.new(2), {Contrast = 0, Brightness = 0, TintColor = Color3.new(1,1,1)}):Play()
TweenService:Create(blur, TweenInfo.new(2), {Size = 0}):Play()
task.wait(2)
if connection then connection:Disconnect() end
spectrum:Destroy()
colorCorrection:Destroy()
blur:Destroy()
bgAmbience:Destroy()
countdownSfx:Destroy()
screenGui:Destroy()
